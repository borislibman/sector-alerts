# ── Alert behavior ────────────────────────────────────────────────────────────
ALERT_PERIOD=1mo          # Yahoo Finance range: 5d | 1mo | 3mo | 6mo | ytd | 1y
ALERT_INTERVAL=1d         # Yahoo Finance interval: 1d | 1wk
ALERT_THRESHOLD=2.0       # Fire threshold alert when |spread| >= this %
REVERSAL_MIN=1.0          # Minimum prior |spread| required to fire a reversal alert
COOLDOWN_HRS=20.0         # Hours before re-firing the same threshold alert for same sector
DESKTOP_ALERTS=true       # Set to false on headless servers

STATE_FILE=sector_state.json

# ── Email (Gmail example — use an App Password, not your account password) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL_TO=you@gmail.com

# ── Twilio SMS ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx
